NEXT_PUBLIC_SITE_URL=https://your-xsvo-domain.example
NEXT_PUBLIC_DOC_URL=https://github.com/xsvo/XSVO-main/tree/main/docs
XSVO_COOKIE_SECURE=true
# Default 0.0.0.0 supports both http://server-ip:4000 and domain reverse proxy.
# Use 127.0.0.1 when you only want access through a local reverse proxy.
XSVO_BIND_HOST=0.0.0.0
XSVO_DATA_DIR=.data
XSVO_INTERNAL_ORIGIN=http://127.0.0.1:4000
# Compatibility names kept for upstream tooling/scripts copied from VOZEB.
VOZEB_COOKIE_SECURE=true
VOZEB_DATA_DIR=.data
VOZEB_INTERNAL_ORIGIN=http://127.0.0.1:4000
